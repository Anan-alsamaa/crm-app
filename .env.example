# ============================================================================
# Yiji CRM — environment configuration (copy to .env and fill in)
# ============================================================================
# NOTE: The DIRECTUS_ADMIN_* values below are WEAK and for LOCAL DEV ONLY.
# Production MUST override them with strong credentials supplied via the
# environment. See README "Production" section.
# ----------------------------------------------------------------------------

# --- Directus (system of record) ---
DIRECTUS_ADMIN_EMAIL=e.habibi@anan.sa
DIRECTUS_ADMIN_PASSWORD=123456
# Generate with: openssl rand -hex 32
DIRECTUS_KEY=replace-with-random-key
DIRECTUS_SECRET=replace-with-random-secret
DIRECTUS_PORT=8055
DIRECTUS_PUBLIC_URL=http://localhost:8055

# --- PostgreSQL ---
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=yiji_crm
DB_USER=directus
DB_PASSWORD=directus

# --- Redis (Socket.IO adapter + BullMQ + AI cache) ---
REDIS_URL=redis://redis:6379

# --- Customer (widget) auth ---
# HS256 shared secret for MVP; RS256 public key supported later via YIJI_JWT_PUBLIC_KEY.
YIJI_JWT_SECRET=replace-with-shared-secret
# YIJI_JWT_PUBLIC_KEY=

# --- Directus service-account static tokens (seeded at bootstrap) ---
SVC_GATEWAY_TOKEN=replace-with-gateway-token
SVC_WORKERS_TOKEN=replace-with-workers-token
SVC_AI_TOKEN=replace-with-ai-token

# --- Custom service ports ---
SOCKET_GATEWAY_PORT=8080
AI_GATEWAY_PORT=8081

# --- AI provider (Gemini, behind AIProvider interface) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# --- Email (SMTP, behind MailTransport interface) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="Yiji Support <support@example.com>"

# --- Yiji platform integration (unset URL => mock client) ---
YIJI_API_URL=
YIJI_API_KEY=

# --- File storage (local | s3) ---
STORAGE_DRIVER=local
# S3-compatible (when STORAGE_DRIVER=s3):
# STORAGE_S3_KEY=
# STORAGE_S3_SECRET=
# STORAGE_S3_BUCKET=
# STORAGE_S3_REGION=
# STORAGE_S3_ENDPOINT=

# --- Frontend (Vite) public vars ---
VITE_DIRECTUS_URL=http://localhost:8055
VITE_SOCKET_URL=http://localhost:8080
VITE_AI_GATEWAY_URL=http://localhost:8081

# --- Runtime mode ---
# Set NODE_ENV=production on the three Node services in prod. It activates the
# Zod env guards (strict CORS, no placeholder secrets, Redis required, SMTP
# required). See docs/PRODUCTION.md → "Configuration & env validation".
NODE_ENV=development
# Strict CORS allow-list for the Node services (comma-separated exact origins).
# `*` is rejected when NODE_ENV=production.
CORS_ORIGIN=*

# --- Observability (OpenTelemetry) ---
# Tracing is OFF unless OTEL_EXPORTER_OTLP_ENDPOINT is set. Point it at any
# OTLP/HTTP collector (e.g. http://otel-collector:4318).
OTEL_EXPORTER_OTLP_ENDPOINT=
# OTEL_EXPORTER_OTLP_HEADERS=authorization=Bearer xxx
# Required for full ESM auto-instrumentation under tsx (set in prod compose):
# NODE_OPTIONS=--import @opentelemetry/instrumentation/hook.mjs

# --- Postgres backup scripts (scripts/backup-pg.sh / restore-pg.sh) ---
# BACKUP_DIR=./backups
# RETENTION_DAYS=7
