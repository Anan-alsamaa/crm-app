# ============================================================================
# Local Directus runner — template. Copy to `.env` (gitignored) and fill in.
# ============================================================================
# Per spec (CLAUDE.md) the Directus database is Postgres — non-negotiable, no
# SQLite. This runner points at a native local Postgres on :5432, database
# `yiji_crm`, app role `directus`. Start with:  npm run bootstrap && npm start
# (the first run installs Directus system tables; subsequent runs just `npm start`).
# Then provision the project schema:  pnpm --filter @yiji/directus-bootstrap apply
# ----------------------------------------------------------------------------

# Generate KEY/SECRET with: openssl rand -hex 32  (keep stable so sessions survive restarts)
KEY=replace-with-random-key
SECRET=replace-with-random-secret

# --- Postgres (native, localhost) ---
DB_CLIENT=pg
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=yiji_crm
DB_USER=directus
DB_PASSWORD=replace-with-directus-role-password

# --- Project owner (weak — LOCAL DEV ONLY, per spec Section 5) ---
ADMIN_EMAIL=e.habibi@anan.sa
ADMIN_PASSWORD=123456

HOST=0.0.0.0
PORT=8055
PUBLIC_URL=http://localhost:8055

# In-memory infra — no Redis/websockets for this single local instance
# (the socket-gateway owns realtime; Directus cache off avoids stale reads).
REDIS_ENABLED=false
WEBSOCKETS_ENABLED=false
CACHE_ENABLED=false
RATE_LIMITER_ENABLED=false
PRESSURE_LIMITER_ENABLED=false
SYNCHRONIZATION_STORE=memory
MESSENGER_STORE=memory

# Allow the portals' Vite dev servers to call Directus
CORS_ENABLED=true
CORS_ORIGIN=true

TELEMETRY=false

# Load hook extensions (lock-project-owner, notify-on-change) from the shared dir
EXTENSIONS_PATH=../extensions
EXTENSIONS_AUTO_RELOAD=true
