      "name": "Read Data",
      "key": "reat_item_cr",
      "type": "item-read",
      "position_x": 6,
      "position_y": 17,
      "resolve": "97876215-e86c-4589-b66b-e6f75e33103f",
      "reject": null,
      "options": {
        "permissions": "$trigger",
        "emitEvents": false,
