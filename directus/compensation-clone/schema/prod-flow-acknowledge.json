    {
      "id": "97876215-e86c-4589-b66b-e6f75e33103f",
      "name": "Run Script",
      "key": "exec_80xye",
      "type": "exec",
      "position_x": 25,
      "position_y": 18,
      "resolve": "4565b884-a017-4cdb-a085-f3c7433c2de8",
      "reject": null,
      "options": {
        "code": "module.exports = async function (data) {\n\n  const slaResponseMinutes = data.reat_item_cr.com_issue.sla.response_hours;\n\n  const now = new Date();\n  const currentTimestamp = now.toISOString();\n\n  const ticketCreatedAt = new Date(data.reat_item_cr.date_created);\n\n  // elapsed time since ticket creation (minutes)\n  const elapsedMinutes = Math.floor((now - ticketCreatedAt) / 60000);\n\n  const isSlaBreached = elapsedMinutes > slaResponseMinutes;\n\n  return {\n    current_timestamp: currentTimestamp,\n    elapsed_minutes: elapsedMinutes,\n    sla_response_minutes: slaResponseMinutes,\n    sla_breached: isSlaBreached\n  };\n};"
      }
    }
  ],
  "ordered_keys": ["reat_item_cr", "exec_80xye", "item_update_iwbon"]
