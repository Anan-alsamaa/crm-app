      "name": "Generate Date",
      "key": "generate_date",
      "type": "exec",
      "position_x": 5,
      "position_y": 20,
      "resolve": "473e8b57-49f8-415f-ae5d-98309456d189",
      "reject": null,
      "options": {
        "code": "module.exports = async function (data) {\n  const now = new Date();\n\n  // Start of today (00:00)\n  const start = new Date(now);\n  start.setHours(0, 0, 0, 0);\n\n  // +1 month\n  const end = new Date(start);\n  end.setMonth(end.getMonth() + 1);\n\n  // Format helpers\n  const formatDateTime = (date, endOfDay = false) => {\n    const d = new Date(date);\n    if (endOfDay) {\n      d.setHours(23, 59, 0, 0);\n    }\n    return d.toISOString().slice(0, 16);\n  };\n\n  const formatISO = (date) => {\n    return date.toISOString();\n  };\n\n  return {\n    ActivationDateTime: formatDateTime(start),\n    ExpirationDateTime: formatDateTime(end, true),\n\n    ActivationDate: formatISO(start),\n    ExpirationDate: formatISO(end),\n  };\n};"
      }
    },
