# syntax=docker/dockerfile:1
# Generic Vite SPA -> static nginx image for the Yiji pnpm monorepo.
# Build one app per image by passing APP_NAME (pnpm package) + APP_DIR (apps/<dir>).
#   docker build -f Dockerfile.web --build-arg APP_NAME=@yiji/agent-portal \
#     --build-arg APP_DIR=agent-portal .
# Vite public env is baked at build time (static SPA), so the browser-facing URLs
# (Directus/socket/ai-gateway on their host-published ports) come in as build args.
FROM node:20-alpine AS build
RUN corepack enable
WORKDIR /app

ARG APP_NAME
ARG VITE_DIRECTUS_URL
ARG VITE_SOCKET_URL
ARG VITE_AI_GATEWAY_URL
ARG VITE_AI_SVC_TOKEN
ARG VITE_WIDGET_JWT_SECRET
ARG VITE_YIJI_API_URL
ARG VITE_YIJI_API_TOKEN
ENV VITE_DIRECTUS_URL=$VITE_DIRECTUS_URL \
    VITE_SOCKET_URL=$VITE_SOCKET_URL \
    VITE_AI_GATEWAY_URL=$VITE_AI_GATEWAY_URL \
    VITE_AI_SVC_TOKEN=$VITE_AI_SVC_TOKEN \
    VITE_WIDGET_JWT_SECRET=$VITE_WIDGET_JWT_SECRET \
    VITE_YIJI_API_URL=$VITE_YIJI_API_URL \
    VITE_YIJI_API_TOKEN=$VITE_YIJI_API_TOKEN

COPY . .
RUN pnpm install --frozen-lockfile
RUN pnpm --filter "$APP_NAME" build

# ---- static runtime ----
FROM nginx:alpine AS runner
ARG APP_DIR
COPY docker/nginx-spa.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/apps/$APP_DIR/dist /usr/share/nginx/html
EXPOSE 80
