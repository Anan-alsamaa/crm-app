# ============================================================================
# Yiji CRM — PRODUCTION environment template
# ----------------------------------------------------------------------------
# Copy to `.env.prod`, fill every value, then: chmod 600 .env.prod  (NEVER commit it).
# Generate the [GENERATE] secrets in one shot:  scripts/gen-prod-secrets.sh
# Deploy:  docker compose -f docker-compose.prod.yml --env-file .env.prod up -d
# Full runbook: docs/PRODUCTION.md   ·   Readiness: docs/GO-LIVE-READINESS.md
#
# The three Node services validate this with Zod at boot and FAIL FAST on a
# missing/placeholder secret, a "*" CORS origin, or a short JWT secret — a
# misconfigured deploy crashes immediately instead of degrading silently.
# ============================================================================

# --- [GENERATE] strong secrets — `openssl rand -hex 32` (use gen-prod-secrets.sh) ---
DIRECTUS_KEY=
DIRECTUS_SECRET=
YIJI_JWT_SECRET=            # >= 32 chars; rotate in lockstep with the widget host page
SVC_GATEWAY_TOKEN=
SVC_WORKERS_TOKEN=
SVC_AI_TOKEN=
DB_PASSWORD=

# --- [PROVIDE] owner account + DB identity ---
DIRECTUS_ADMIN_EMAIL=admin@yourcompany.com
DIRECTUS_ADMIN_PASSWORD=   # strong — NEVER 123456
DB_USER=yiji_app           # a distinct service user, not "directus"
DB_DATABASE=yiji_crm

# --- [PROVIDE] public URLs / domains (all HTTPS) ---
DIRECTUS_PUBLIC_URL=https://directus.yourcompany.com
# Exact portal origins for the ADMIN/AI APIs, comma-separated. "*" is REJECTED here.
CORS_ORIGIN=https://agent.yourcompany.com,https://admin.yourcompany.com
# Customer WIDGET socket CORS. The widget embeds on arbitrary vendor sites, so this
# defaults to "*" and MAY stay "*" — the connection is gated by the signed customer
# JWT, not its origin. Set an explicit list only if the widget lives on known domains.
WIDGET_CORS_ORIGIN=*

# --- [PROVIDE] managed datastores (private network) ---
DB_HOST=your-postgres-host
DB_PORT=5432
REDIS_URL=redis://your-redis-host:6379     # password-protected / TLS
DIRECTUS_INTERNAL_URL=http://directus:8055 # in-cluster URL the services call Directus on
AI_GATEWAY_URL=http://ai-gateway:8081      # in-cluster URL workers call the AI gateway on

# --- [PROVIDE] SMTP — notifications + scheduled reports (workers refuse to boot without SMTP_HOST) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="Yiji Support <support@yourcompany.com>"

# --- [PROVIDE] portal build args — baked at image build (client-visible, NON-secret) ---
VITE_DIRECTUS_URL=https://directus.yourcompany.com
VITE_SOCKET_URL=https://gateway.yourcompany.com
VITE_AI_GATEWAY_URL=https://ai.yourcompany.com
# Admin "Import CSV" + "Run report now" post here = the socket-gateway HTTP base URL.
VITE_JOB_PRODUCER_URL=https://gateway.yourcompany.com

# --- [PROVIDE] Yiji commerce API — REQUIRED: ai-gateway refuses to boot without it ---
# Host ONLY — do NOT append /api. The client adds the path itself, so
# `https://host/api` would request `https://host/api/api/Order/...` → 404.
# An empty value would fall back to the mock commerce client and serve demo
# fixtures (Demo Customer, order O-5921) to real agents; the production config
# guard rejects that at boot rather than let it ship fake data.
YIJI_API_URL=                # e.g. https://admin.example.com  (no trailing /api)
YIJI_API_KEY=                # bearer token for the Yiji API, if it requires one

# --- [OPTIONAL] AI (Gemini); empty => AI endpoints return 503 not_configured ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# --- [OPTIONAL] container image source (CI sets these on rollout) ---
REGISTRY=ghcr.io/your-org
IMAGE_TAG=latest

# --- [OPTIONAL] inbound webhooks (HMAC-SHA256); empty => POST /webhooks/yiji returns 503 ---
YIJI_WEBHOOK_SECRET=
WEBHOOK_TOLERANCE_SEC=300

# --- [OPTIONAL] observability — point at any OTLP/HTTP collector ---
OTEL_EXPORTER_OTLP_ENDPOINT=
# Leave NODE_OPTIONS unset. Preloading the OTel hook crashes every service at
# boot unless @opentelemetry/instrumentation resolves from the app root — under
# `pnpm --prod` it is a transitive dep, so it does not. Setting this crash-loops
# socket-gateway, workers and ai-gateway behind `restart: unless-stopped`.
# NODE_OPTIONS=--import @opentelemetry/instrumentation/hook.mjs

# --- [OPTIONAL] attachment + rate-limit policy (sane defaults applied if unset) ---
# ATTACHMENT_MAX_BYTES=10485760
# ATTACHMENT_ALLOWED_MIME=image/png,image/jpeg,image/gif,image/webp,application/pdf,text/plain
# MSG_RATE_CAPACITY=20
# MSG_RATE_REFILL_PER_SEC=5

# --- [OPTIONAL] published host ports — single-host compose only (behind an LB in real prod) ---
# Real prod terminates TLS at the LB and exposes only /jobs/* + /webhooks/* of the
# gateway HTTP port publicly, keeping /metrics + /debug/* internal.
# DIRECTUS_PORT=8055
# SOCKET_GATEWAY_PORT=8080
# SOCKET_GATEWAY_HTTP_PORT=8082
# AI_GATEWAY_PORT=8081
# AGENT_PORTAL_PORT=8090
# ADMIN_PORTAL_PORT=8092
